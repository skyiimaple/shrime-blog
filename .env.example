# Payload — 必填，至少 32 位随机字符串
PAYLOAD_SECRET=your-secret-key-at-least-32-characters-long

# 数据库 — 本地与生产均使用 Neon PostgreSQL
# Serverless 建议使用 Neon 的 Pooler 连接串（主机名含 -pooler）
# 示例：postgresql://...@ep-xxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URI=postgresql://user:password@host:5432/dbname?sslmode=require

# 站点 URL — 生产环境改为正式域名
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Vercel Blob — 在 Vercel 控制台添加 Blob 存储后自动注入
# 本地开发可不配，媒体文件会存到 media/ 目录
BLOB_READ_WRITE_TOKEN=

# Meilisearch（可选，不配则搜索不可用）
MEILISEARCH_HOST=
MEILISEARCH_API_KEY=
